# Landing waitlist — Brevo Contacts API (called from the browser).
# Get key: https://app.brevo.com/settings/keys/api
# VITE_* is exposed in the client bundle — use a restricted key and rotate if leaked.
VITE_BREVO_API_KEY=
#VITE_BREVO_API_KEY=xkeysib-example

# Optional: Contacts → Lists → ID
VITE_BREVO_LIST_ID=2
#VITE_BREVO_LIST_ID=3

# Optional: override Brevo URL (e.g. same-origin reverse proxy in production)
#VITE_BREVO_API_URL=https://api.brevo.com/v3/contacts

# App API — local FastAPI (default port 8000)
VITE_API_BASE_URL=http://127.0.0.1:8000
# Dev default: sign in via /api/auth (SQLite/local DB) — no Supabase browser client.
# Set to false to use Supabase auth in dev when VITE_SUPABASE_* are set.
#VITE_USE_LOCAL_API_AUTH=true
#VITE_API_BASE_URL=http://localhost:8000
#VITE_API_BASE_URL=https://api.yourdomain.com

# Supabase (browser auth). For hosted project: Dashboard → Project Settings → API.
# For local Supabase CLI (`supabase start`), use the API URL and anon key printed in the terminal.
# Authentication → URL Configuration: add http://localhost:5173 and http://127.0.0.1:5173 to Redirect URLs.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
#VITE_SUPABASE_URL=https://your-project.supabase.co
#VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example
# Local Supabase:
#VITE_SUPABASE_URL=http://127.0.0.1:54321
#VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example-local-anon
