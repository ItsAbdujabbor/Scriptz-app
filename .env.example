# =============================================================================
# Clixa-app — frontend environment template (Vite)
# -----------------------------------------------------------------------------
# 1. Copy this file to `.env` in the same directory.
# 2. Fill in every value marked `<fill-me>` or leave blank to disable.
# 3. Only VITE_* variables are exposed to the browser.
# 4. Anything pasted here ships in the client bundle — use only public keys.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# 1. App API (FastAPI backend)
# -----------------------------------------------------------------------------
# Local dev: leave blank → Vite proxies /api → 127.0.0.1:8000 (no CORS issues).
# Prod:     set to your deployed API origin.
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=
#VITE_API_BASE_URL=http://127.0.0.1:8000
#VITE_API_BASE_URL=https://api.clixa.ai

# CloudWatch RUM (frontend monitoring). Leave blank in dev to disable.
# Prod values for clixa-app:
#   VITE_RUM_APP_ID=d48c48b1-3f38-4190-a73c-c907f7c3c6de
#   VITE_RUM_IDENTITY_POOL_ID=us-east-1:18e41ce8-8001-468e-a4bf-34e014e481f1
VITE_RUM_APP_ID=
VITE_RUM_IDENTITY_POOL_ID=
VITE_RUM_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# 2. OAuth federation (Google — direct, no AWS)
# -----------------------------------------------------------------------------
# Public Client ID only. The matching CLIENT SECRET lives in the backend's
# .env (OAUTH_GOOGLE_CLIENT_SECRET) and never ships to the browser.
#
# Make sure http://localhost:5173/ is registered as a redirect URI on the
# OAuth client (Google Cloud Console → Credentials). Trailing slash matters.
# ─────────────────────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=<fill-me>.apps.googleusercontent.com


# ─────────────────────────────────────────────────────────────────────────────
# 3. Paddle Billing (Paddle.js checkout)
# -----------------------------------------------------------------------------
# This must be the "Client-side token" from Paddle dashboard
# (Developer tools → Authentication → Client-side tokens). Public — safe to ship.
# Must match the same Paddle environment as the backend's PADDLE_ENV.
# ─────────────────────────────────────────────────────────────────────────────
VITE_PADDLE_ENV=sandbox                # sandbox | production
VITE_PADDLE_CLIENT_TOKEN=<fill-me-public-client-token>


# ─────────────────────────────────────────────────────────────────────────────
# 4. Waitlist (landing page — Brevo contacts API)
# -----------------------------------------------------------------------------
# https://app.brevo.com/settings/keys/api — use a restricted key since it ships
# in the client bundle. Rotate if leaked. Leave blank to disable waitlist form.
# ─────────────────────────────────────────────────────────────────────────────
VITE_BREVO_API_KEY=
VITE_BREVO_LIST_ID=2
# Optional: same-origin reverse proxy override
#VITE_BREVO_API_URL=https://api.brevo.com/v3/contacts
