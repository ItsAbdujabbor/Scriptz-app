# Landing waitlist — Brevo Contacts API (called from the browser).
# Get key: https://app.brevo.com/settings/keys/api
# VITE_* is exposed in the client bundle — use a restricted key and rotate if leaked.
VITE_BREVO_API_KEY=
# Optional: Contacts → Lists → ID
VITE_BREVO_LIST_ID=2

# Optional: override Brevo URL (e.g. same-origin reverse proxy in production)
# VITE_BREVO_API_URL=https://api.brevo.com/v3/contacts

# App API (auth, dashboard, …)
# VITE_API_BASE_URL=http://localhost:8000
